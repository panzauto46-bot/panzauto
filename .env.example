# Optional: disable Vite hot module replacement.
# Useful in environments where file watching causes UI flicker.
DISABLE_HMR="false"

# Optional: public app URL (reserved for future integrations).
APP_URL="http://localhost:3000"

# Optional: Google Analytics Measurement ID.
# Format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=""

# Required for Google Sign-In.
VITE_GOOGLE_CLIENT_ID=""

# Optional comma-separated owner emails.
# Any listed Google account will be redirected to /dashboard after sign-in.
VITE_OWNER_EMAILS=""
